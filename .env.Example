# Environment Configuration for DB-Stream
# Copy this file to .env and update values as needed

# Service Configuration
SERVER_PORT=8080
LOG_LEVEL=info
LOG_FORMAT=json

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=db-stream-group

# Database Configuration (PostgreSQL - Source)
DB_HOST=localhost
DB_PORT=5432
DB_USER=db_stream
DB_PASSWORD=db_stream_password
DB_NAME=db_stream_source

# ClickHouse Configuration (Analytics)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
# HTTP endpoint for lightweight tools/consumers (optional override)
CLICKHOUSE_HTTP_URL=http://localhost:8123
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=db_stream_analytics

# Schema History -> ClickHouse DDL Applier
# Optional explicit topic list; if empty, topics are auto-discovered by regex.
SCHEMA_HISTORY_TOPICS=
# Default matches Debezium MySQL pattern: <source>.schema-history
SCHEMA_HISTORY_TOPIC_REGEX=.*\.schema-history$
# Optional source-to-mirror DB mapping, comma-separated source:target pairs.
# Example: mysql_employee_mirror:mysql_employee_mirror,pg_orion:pg_orion_mirror
SOURCE_TO_MIRROR_DB_MAP=
# Consumer behavior
KAFKA_START_OFFSET=earliest
COMMIT_ON_ERROR=true
TOPIC_DISCOVERY_INTERVAL=30s
# Safety controls
DRY_RUN=false
ALLOW_DROP_COLUMNS=false

# Redis Configuration (Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# AWS Credentials (for ClickHouse S3Queue / S3 sources; leave empty for IAM roles)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: AWS region for S3 (e.g. ap-south-1)
AWS_REGION=us-east-1

# Development Environment
GO_ENV=development
AIR_ROOT_PATH=.
